{
  "name": "claude-stack",
  "owner": {
    "name" : "Josef Hardi",
    "email": "josef.hardi@gmail.com",
    "url"  : "https://github.com/johardi"
  },
  "metadata": {
    "description": "My personal plugins for code development and standardization that provides reusable components, agents, and tools to maintain consistency across projects",
    "version": "1.0.0"
  },
  "plugins": [
    {
      "name": "cstack-essential",
      "source": "./plugins/cstack-essential",
      "description": "Essential development bundle with onboarding commands, GitHub issue analysis and fixes, audio notification hooks on Claude Code events, and integrated MCP servers",
      "version": "1.2.0",
      "homepage": "https://github.com/johardi/claude-stack",
      "repository": "https://github.com/johardi/claude-stack",
      "license": "MIT",
      "keywords": ["essential"],
      "category": "code-development",
      "strict": false,
      "hooks": {
        "Notification": [{
          "hooks": [{
              "type": "command",
              "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/scripts/play-sound/play_sound.py\" && python \"${CLAUDE_PLUGIN_ROOT}/scripts/play-sound/play_sound.py\" || true"
            }]
        }],
        "Stop": [{
          "hooks": [{
              "type": "command",
              "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/scripts/play-sound/play_sound.py\" && python \"${CLAUDE_PLUGIN_ROOT}/scripts/play-sound/play_sound.py\" || true"
            }]
        }],
        "PreToolUse": [{
          "matcher": "Edit|MultiEdit|Write|NotebookEdit|TodoWrite|Bash|Read|NotebookRead",
          "hooks": [{
              "type": "command",
              "command": "test -f \"${CLAUDE_PLUGIN_ROOT}/scripts/play-sound/play_sound.py\" && python \"${CLAUDE_PLUGIN_ROOT}/scripts/play-sound/play_sound.py\" || true"
            }]
        }]
      },
      "mcpServers": {
        "serena": {
          "type": "stdio",
          "command": "uvx",
          "args": [
            "--from", 
            "git+https://github.com/oraios/serena",
            "serena", 
            "start-mcp-server",
            "--open-web-dashboard",
            "False",
            "--project",
            "\"$(pwd)\""
          ]
        },
        "ref": {
          "type": "stdio",
          "command": "npx",
          "args": ["ref-tools-mcp@latest"]
        }
      }
    }
  ]
}
