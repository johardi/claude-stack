{
  "description": "Enforce ontology-builder workflow guardrails",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__owl__add_axiom|mcp__owl__add_axioms|mcp__owl__remove_axiom|mcp__owl__add_prefix|mcp__owl__set_ontology_iri",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-approved-proposal.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-owl-hand-edit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
